{
  "name": "rms-v1-backend",
  "version": "1.0.0",
  "description": "Retail Management System V1 — Node.js / Express / PostgreSQL backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:schema": "psql -U $DB_USER -d $DB_NAME -f src/database/schema.sql",
    "db:seed": "psql -U $DB_USER -d $DB_NAME -f src/database/seeders/seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

# ── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────
# On Render/Heroku, set DATABASE_URL (the managed connection string) instead of
# the individual DB_* vars below. SSL is enabled automatically in production,
# or force it with DB_SSL=true.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_SSL=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rms_v1
DB_USER=postgres
DB_PASSWORD=2580

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES=8h

# ── WhatsApp Business API (optional) ─────────────────────
WHATSAPP_TOKEN=your_meta_access_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=rms_verify
